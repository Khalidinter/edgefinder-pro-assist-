{
  "builds": [
    { "src": "api/*.py", "use": "@vercel/python" }
  ],
  "functions": {
    "api/cron_refresh.py": { "maxDuration": 300 },
    "api/cron_fetch_history.py": { "maxDuration": 300 },
    "api/backtest.py": { "maxDuration": 300 }
  },
  "routes": [
    { "src": "/api/health", "dest": "/api/health.py" },
    { "src": "/api/data", "dest": "/api/data.py" },
    { "src": "/api/backtest", "dest": "/api/backtest.py" },
    { "src": "/api/cron/refresh", "dest": "/api/cron_refresh.py" },
    { "src": "/api/cron_refresh", "dest": "/api/cron_refresh.py" },
    { "src": "/api/cron/fetch-history", "dest": "/api/cron_fetch_history.py" },
    { "src": "/api/cron_fetch_history", "dest": "/api/cron_fetch_history.py" },
    { "src": "/(.*)", "dest": "/api/index.py" }
  ],
  "crons": [
    { "path": "/api/cron/refresh", "schedule": "0 16 * * *" }
  ]
}
